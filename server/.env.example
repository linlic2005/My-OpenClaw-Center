# OpenClaw Web Console Server Configuration
# Copy this file to .env and replace placeholder values before running in production.

# Server
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Database
DB_PATH=./data/openclaw.db

# Gateway
# Use mock for local UI work, real for production or gateway-backed testing.
GATEWAY_MODE=mock
GATEWAY_URL=http://127.0.0.1:3000
GATEWAY_TOKEN=your-gateway-secret-token
GATEWAY_TIMEOUT=10000

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info

# Admin seed
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
